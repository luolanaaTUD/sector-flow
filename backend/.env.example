# Copy to .env and fill in values
DATABASE_URL=postgresql+psycopg://sector_flow:sector_flow@localhost:5432/sector_flow

# Server
APP_HOST=0.0.0.0
APP_PORT=8000

# Collector
COLLECTOR_ENABLED=true
# Comma-separated list of sector types to collect: industry,concept
SECTOR_TYPES=industry,concept
# Request delay between AkShare calls (seconds)
AKSHARE_REQUEST_DELAY=2
