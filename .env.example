POSTGRES_USER=sector_flow
POSTGRES_PASSWORD=sector_flow
POSTGRES_DB=sector_flow
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://sector_flow:sector_flow@db:5432/sector_flow
NEXT_PUBLIC_API_URL=http://localhost:8000

COLLECTOR_ENABLED=true
SECTOR_TYPES=industry,concept
AKSHARE_REQUEST_DELAY=2
CONCEPT_ALLOWLIST_ENABLED=true
CONCEPT_ALLOWLIST_FILE=backend/app/collector/data/concept_allowlist.txt

