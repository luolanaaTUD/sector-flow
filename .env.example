POSTGRES_USER=sector_flow
POSTGRES_PASSWORD=sector_flow
POSTGRES_DB=sector_flow
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://sector_flow:sector_flow@db:5432/sector_flow
NEXT_PUBLIC_API_URL=http://localhost:8000

COLLECTOR_ENABLED=true
SECTOR_TYPES=industry,concept
AKSHARE_REQUEST_DELAY=2

# --- Tencent / production (use with: docker compose -f compose.yaml -f compose.tencent.yaml up -d)
# After building and pushing to TCR, set these on the CVM:
# BACKEND_IMAGE=ccr.ccs.tencentyun.com/<namespace>/sector-flow-backend:<tag>
# FRONTEND_IMAGE=ccr.ccs.tencentyun.com/<namespace>/sector-flow-frontend:<tag>
# Optional: mirror Timescale image to TCR and set:
# TIMESCALE_IMAGE=ccr.ccs.tencentyun.com/<namespace>/timescaledb:2.17.2-pg16
